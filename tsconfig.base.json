{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "es2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@artsite/blocks": ["packages/blocks/src/index.ts"],
      "@artsite/db": ["packages/db/src/index.ts"],
      "@artsite/ui": ["packages/ui/src/index.ts"]
    }
  }
}

